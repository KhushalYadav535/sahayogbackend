  tenantId           String
  overrideId         String // Unique override reference
  ruleBypassed       String // Which approval rule was bypassed
  originalApprover   String // Who should have approved
  overrideAuthorizer String // Who authorized the override
  reasonCode         String // From exception.override.reason.codes metadata
  reasonDescription  String?
  transactionType    String // LOAN | GL_ENTRY | REFUND | MEMBER_STATUS | DEPOSIT
  transactionId      String?
  amount             Decimal? @db.Decimal(15, 2)
  createdAt          DateTime @default(now())
  createdBy          String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, overrideId])
  @@map("approval_overrides")
}

// ─── GOV-008: Maker-Checker Configuration (Metadata) ──────────────────────────
model ApprovalThreshold {
  id              String   @id @default(cuid())
  tenantId        String
  transactionType String // LOAN | GL_ENTRY | REFUND | MEMBER_STATUS | DEPOSIT
  level           Int // 1-4
  maxAmount       Decimal? @db.Decimal(15, 2)
  approverRole    String // LOAN_OFFICER | LOAN_COMMITTEE | PRESIDENT | SECRETARY
  slaHours        Int      @default(24) // SLA in hours
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, transactionType, level])
  @@map("approval_thresholds")
}

