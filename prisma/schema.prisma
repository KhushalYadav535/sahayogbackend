// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

model AiAuditLog {
  id                 String   @id @default(cuid())
  tenantId           String?
  userId             String?
  feature            String // duplicate_detection | risk_scoring | etc
  inputData          Json?
  outputData         Json?
  confidence         Decimal? @db.Decimal(5, 4)
  latencyMs          Int?
  success            Boolean  @default(true)
