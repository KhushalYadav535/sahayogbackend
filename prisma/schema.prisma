// ─────────────────────────────────────────────
// MODULE 8 — RISK & CONTROLS
// ─────────────────────────────────────────────

// RSK-003: Concurrent Session Control
model Session {
  id             String   @id @default(cuid())
  userId         String
  tenantId       String?
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  lastActivityAt DateTime @default(now())
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// RSK-005: Password History & Rotation
model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_history")
}

// RSK-001: Transaction Velocity Tracking
model TransactionVelocity {
  id              String   @id @default(cuid())
  tenantId        String
  accountId       String
  transactionType String
  amount          Decimal  @db.Decimal(15, 2)
  createdAt       DateTime @default(now())

  @@index([tenantId, accountId, transactionType, createdAt])
  @@map("transaction_velocity")
}

// RSK-002: Daily Transaction Limits Tracking
model DailyLimit {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  accountId   String?
  limitType   String // USER_CASH | ACCOUNT_CASH
  date        DateTime @db.Date
  amountUsed  Decimal  @default(0) @db.Decimal(15, 2)
  limitAmount Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, userId, accountId, limitType, date])
  @@index([tenantId, date])
  @@map("daily_limits")
}

// RSK-006: Data Masking Unmask Log
model DataMaskingLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  field      String // aadhaar | pan | bank_account | mobile
  entityType String // Member | User | Account
  entityId   String
  purpose    String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("data_masking_logs")
}

// RSK-007: Backup Verification Log
model BackupVerification {
  id               String   @id @default(cuid())
  tenantId         String?
  backupDate       DateTime @db.Date
  verificationDate DateTime @default(now())
  status           String // SUCCESS | FAILED
  rowCountLive     Int?
  rowCountBackup   Int?
  errorMessage     String?
  verifiedBy       String? // System or user ID
  createdAt        DateTime @default(now())

  @@unique([backupDate])
  @@index([status])
  @@map("backup_verifications")
}

// RSK-010: Audit Log Hash Chain (for immutability verification)
model AuditLogHash {
  id           String   @id @default(cuid())
  auditLogId   String   @unique
  hash         String // SHA-256 hash of audit log entry + previous hash
  previousHash String? // Hash of previous audit log entry
  createdAt    DateTime @default(now())

  @@index([hash])
  @@map("audit_log_hashes")
}

// RSK-011: Data Retention Policy Tracking
model DataRetention {
  id             String    @id @default(cuid())
  tenantId       String?
  dataCategory   String // TRANSACTION | AUDIT_LOG | KYC_AML | AI_DECISION | MEMBER | COMMUNICATION
  recordId       String
  retentionUntil DateTime
  archivedAt     DateTime?
  purgedAt       DateTime?
  status         String    @default("ACTIVE") // ACTIVE | ARCHIVED | PURGED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, dataCategory, status])
  @@index([retentionUntil])
  @@map("data_retention")
}

// RSK-012: AML Transaction Alerts
model AmlAlert {
  id            String    @id @default(cuid())
  tenantId      String
  memberId      String?
  transactionId String?
  alertType     String // CTR | STRUCTURING | PEP | UNUSUAL_PATTERN
  ruleId        String?
  amount        Decimal   @db.Decimal(15, 2)
  description   String
  status        String    @default("PENDING") // PENDING | REVIEWED | DISMISSED | STR_GENERATED
  reviewedBy    String?
  reviewedAt    DateTime?
  strGenerated  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  member Member? @relation(fields: [memberId], references: [id])

  @@index([tenantId, status])
  @@index([memberId])
  @@map("aml_alerts")
}

// ─────────────────────────────────────────────
// MODULE 9 — SECURITY & RBAC
