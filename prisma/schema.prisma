// Sahayog AI — Prisma Schema
// Prisma Postgres (db.prisma.io) — auto-generated IDs via cuid

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL moved to prisma.config.ts for Prisma 7
}

// ─────────────────────────────────────────────
// PLATFORM & TENANT (US1)
// ─────────────────────────────────────────────

model Tenant {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  district     String?
  state        String?
  regNumber    String?
  plan         String    @default("starter") // starter | pro | enterprise
  status       String    @default("active") // trial | active | suspended | inactive | reactivated | offboarded
  trialEndsAt  DateTime?
  offboardedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members                Member[]
  sbAccounts             SbAccount[]
  loans                  Loan[]
  glEntries              GlEntry[]
  vouchers               Voucher[]
  glAccounts             GlAccount[]
  config                 SystemConfig[]
  configVersions         TenantConfigVersion[]
  users                  User[]
  permissionMatrix       PermissionMatrix[]
  deposits               Deposit[]
  bodDirectors           BodDirector[]
  committees             Committee[]
  agms                   Agm[]
  resolutions            Resolution[]
  complianceEvents       ComplianceEvent[]
  bylaws                 Bylaw[]
  meetingMinutes         MeetingMinutes[]
  approvalOverrides      ApprovalOverride[]
  approvalThresholds     ApprovalThreshold[]
  groupLoans             GroupLoan[] // LN-023
  billingOverride        TenantBilling?
  credits                TenantCredits?
  usageSnapshots         TenantUsageSnapshot[]
  suspenseEntries        SuspenseEntry[]
  bankStatementUploads   BankStatementUpload[]
  paymentRequests        PaymentRequest[]
  notificationLogs       NotificationLog[]
  interestSchemes        InterestScheme[]
  interestAccruals       InterestAccrual[]
  memberPhotos           MemberPhoto[]
  memberSignatures       MemberSignature[]
  recalculationRequests  RecalculationRequest[]
  loanProducts           LoanProduct[] // BRD v5.0 LN-P01
  loanDocumentChecklists LoanDocumentChecklist[] // BRD v5.0 LN-DC01
  collaterals            Collateral[] // BRD v5.0 LN-COL01
  creditAppraisalNotes   CreditAppraisalNote[] // BRD v5.0 LN-CAN01
  loanSanctionLetters    LoanSanctionLetter[] // BRD v5.0 LN-CAN05
  disbursementVouchers   DisbursementVoucher[] // BRD v5.0 LN-DIS05

  // ACC-006: Month-End Closing
  closedPeriods String[] @default([]) // Array of closed periods (YYYY-MM format)
  closedFys     String[] @default([]) // Array of closed financial years

  @@map("tenants")
}

model TenantCredits {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  txCredits  Int      @default(0)
  smsCredits Int      @default(0)
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_credits")
}

model TenantUsageSnapshot {
  id              String   @id @default(cuid())
  tenantId        String
  period          String // YYYY-MM
  activeUsersPeak Int      @default(0)
  memberCount     Int      @default(0)
  txnVolume       Int      @default(0)
  storageMb       Int      @default(0)
  aiInvocations   Int      @default(0)
  apiCalls        Int      @default(0)
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, period])
  @@map("tenant_usage_snapshots")
}

model SystemConfig {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@map("system_config")
}

// MT-003: Tenant-level MDA config versions for rollback
model TenantConfigVersion {
  id        String   @id @default(cuid())
  tenantId  String
  key       String // e.g. "mda"
  value     String // JSON snapshot
  version   Int      @default(1)
  createdBy String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_config_versions")
}

// OTP codes for member login (SMS flow)
model OtpCode {
  id        String   @id @default(cuid())
  tenantId  String
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([tenantId, phone])
  @@map("otp_codes")
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  tenantId            String?
  email               String    @unique
  passwordHash        String
  name                String
  role                String    @default("staff") // superadmin | admin | staff | member
  status              String    @default("active")
  // RSK-005: Password Rotation
  passwordChangedAt   DateTime  @default(now())
  passwordExpiresAt   DateTime?
  passwordForceExpire Boolean   @default(false)
  // SEC-002: Multi-Factor Authentication
  mfaEnabled          Boolean   @default(false)
  mfaMethod           String? // TOTP | SMS
  totpSecret          String? // Base32 encoded secret for TOTP
  totpBackupCodes     String[]  @default([]) // Backup codes for TOTP
  mfaVerifiedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant                Tenant?                @relation(fields: [tenantId], references: [id])
  auditLogs             AuditLog[]
  sessions              Session[]
  passwordHistory       PasswordHistory[]
  dataMaskingLogs       DataMaskingLog[]
  mfaLogs               MfaLog[]
  roleAssignments       RoleAssignmentLog[]    @relation("RoleAssigner")
  roleAssignmentLogs    RoleAssignmentLog[]
  recalculationRequests RecalculationRequest[] @relation("RecalculationRequester")

  @@map("users")
}

// ─────────────────────────────────────────────
// MEMBER LIFECYCLE (US2)
// ─────────────────────────────────────────────

model Member {
  id                   String    @id @default(cuid())
  tenantId             String
  memberNumber         String
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  gender               String?
  phone                String?
  email                String?
  address              String?
  village              String?
  district             String?
  state                String?
  pincode              String?
  aadhaarNumber        String?
  panNumber            String?
  occupation           String?
  status               String    @default("active") // active | dormant | exited | deceased | suspended | blacklisted
  kycStatus            String    @default("pending") // pending | verified | rejected
  kycVerifiedAt        DateTime?
  form15Status         String? // MEM-020: EXEMPT | NOT_EXEMPT
  form15Fy             String? // FY when form15 last applied
  joinDate             DateTime  @default(now())
  exitDate             DateTime?
  exitReason           String?
  isMinor              Boolean   @default(false)
  guardianName         String?
  majorityDate         DateTime?
  // MEM-012: Joint Membership
  jointMemberId        String? // Link to joint holder member
  jointMode            String? // EITHER_OR_SURVIVOR | JOINTLY
  // MEM-014: KYC Re-validation
  kycLastValidatedAt   DateTime? // Last KYC validation date
  kycNextValidationDue DateTime? // Next validation due date
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  shareLedger            ShareLedger[]
  nominees               Nominee[]
  sbAccounts             SbAccount[]
  loans                  Loan[]
  loanApplications       LoanApplication[]
  deposits               Deposit[]
  jointMember            Member?                 @relation("JointMembers", fields: [jointMemberId], references: [id])
  jointMembers           Member[]                @relation("JointMembers")
  groupLoanMembers       GroupLoanMember[]
  amlAlerts              AmlAlert[]
  dataAccessRequests     DataAccessRequest[]
  dataCorrectionRequests DataCorrectionRequest[]
  dataErasureRequests    DataErasureRequest[]
  consentRecords         ConsentRecord[]
  nachMandates           NachMandate[]
  notificationLogs       NotificationLog[]
  photos                 MemberPhoto[]
  signatures             MemberSignature[]

  @@unique([tenantId, memberNumber])
  @@map("members")
}

model ShareLedger {
  id              String   @id @default(cuid())
  memberId        String
  tenantId        String
  transactionType String // purchase | refund | transfer
  shares          Int
  faceValue       Decimal  @db.Decimal(10, 2)
  amount          Decimal  @db.Decimal(12, 2)
  date            DateTime @default(now())
  remarks         String?
  createdAt       DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@map("share_ledger")
}

model Nominee {
  id           String    @id @default(cuid())
  memberId     String
  name         String
  relationship String
  dateOfBirth  DateTime?
  sharePercent Int       @default(100)
  phone        String?
  address      String?
  createdAt    DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@map("nominees")
}

// ─────────────────────────────────────────────
// SAVINGS BANK (US3)
// ─────────────────────────────────────────────

model SbAccount {
  id                 String    @id @default(cuid())
  tenantId           String
  memberId           String
  accountNumber      String
  accountType        String    @default("savings") // savings | current | fd | rd
  balance            Decimal   @default(0) @db.Decimal(15, 2)
  interestRate       Decimal   @default(3.5) @db.Decimal(5, 2)
  operationMode      String    @default("SINGLE") // SINGLE | EITHER_OR_SURVIVOR | JOINTLY
  nominee            String?
  status             String    @default("active") // active | dormant | closed
  lastActivityAt     DateTime? @default(now()) // SB-005 dormancy
  kycRefreshRequired Boolean   @default(false) // COA: required for dormancy reactivation
  openedAt           DateTime  @default(now())
  closedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  member       Member        @relation(fields: [memberId], references: [id])
  transactions Transaction[]

  @@unique([tenantId, accountNumber])
  @@map("sb_accounts")
}

model Transaction {
  id           String   @id @default(cuid())
  accountId    String
  type         String // credit | debit
  category     String // deposit | withdrawal | transfer | interest | emi | fee
  amount       Decimal  @db.Decimal(15, 2)
  balanceAfter Decimal  @db.Decimal(15, 2)
  reference    String?
  remarks      String?
  processedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  account SbAccount @relation(fields: [accountId], references: [id])

  @@map("transactions")
}

// ─────────────────────────────────────────────
// DEPOSITS (FDR/RD/MIS) — Module 5
// ─────────────────────────────────────────────

model Deposit {
  id              String    @id @default(cuid())
  tenantId        String
  memberId        String
  depositNumber   String // unique per tenant
  depositType     String // fd | rd | mis
  principal       Decimal   @db.Decimal(15, 2)
  interestRate    Decimal   @db.Decimal(5, 2)
  tenureMonths    Int // FDR/MIS: tenure; RD: installments
  compoundingFreq String    @default("quarterly") // monthly | quarterly | half_yearly | yearly
  maturityDate    DateTime?
  maturityAmount  Decimal?  @db.Decimal(15, 2) // calculated at maturity
  rdMonthlyAmount Decimal?  @db.Decimal(15, 2) // RD installment
  status          String    @default("active") // active | matured | prematurely_closed | lien_marked | dormant | unclaimed
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  // CoA fields
  isSeniorCitizen Boolean   @default(false) // COA: auto-detected from member DOB (age >= 60)
  lienLoanId      String? // COA: DEP-010 — FDR lien for Loan Against Deposit
  tdsDeducted     Decimal?  @db.Decimal(15, 2) // COA: cumulative TDS deducted on this deposit
  tdsApplicable   Boolean   @default(false) // COA: whether TDS applies this FY
  form15Exempt    Boolean   @default(false) // COA: Form 15G/H submitted
  accruedInterest Decimal   @default(0) @db.Decimal(15, 2) // running accrued interest
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@unique([tenantId, depositNumber])
  @@map("deposits")
}

// ─────────────────────────────────────────────
// LOAN LIFECYCLE (US4)
// ─────────────────────────────────────────────

model LoanApplication {
  id                String    @id @default(cuid())
  tenantId          String
  memberId          String
  guarantorMemberId String? // LN-014 guarantor (if existing member) - DEPRECATED, use guarantorIds
  loanType          String // personal | agricultural | business | housing | education | gold
  loanSubType       String? // COA: kcc | crop | livestock | gold | lad | shg | msme | housing | staff | micro | personal
  amountRequested   Decimal   @db.Decimal(15, 2)
  purpose           String?
  tenureMonths      Int
  moratoriumMonths  Int       @default(0) // LN-005
  riskScore         Decimal?  @db.Decimal(5, 2)
  riskCategory      String? // LOW | MEDIUM | HIGH | GREEN | AMBER | RED
  status            String    @default("APPLIED") // BRD v5.0: APPLIED | UNDER_REVIEW | PENDING_SANCTION | SANCTIONED | SANCTION_ACKNOWLEDGED | REJECTED | DISBURSED | PARTIALLY_DISBURSED
  remarks           String?
  appliedAt         DateTime  @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // BRD v5.0 LN-F01 to LN-F05: Enhanced application fields
  productId           String? // Link to LoanProduct
  employmentType      String? // SALARIED | SELF_EMPLOYED | FARMER | BUSINESS | OTHER
  monthlyIncome       Decimal? @db.Decimal(15, 2)
  existingLiabilities String? // Free text
  propertyAssetDesc   String? // For secured loans
  guarantorIds        String[] @default([]) // Multiple guarantors (LN-F05)

  member              Member                @relation(fields: [memberId], references: [id])
  loan                Loan?
  product             LoanProduct?          @relation(fields: [productId], references: [id])
  // LN-023: Group Loan/JLG
  groupLoanId         String? // Link to GroupLoan if part of JLG application
  // BRD v5.0 relations
  documentTrackers    LoanDocumentTracker[]
  collateral          Collateral?
  creditAppraisalNote CreditAppraisalNote?
  sanctionLetter      LoanSanctionLetter?

  @@map("loan_applications")
}

// ─── LN-023: Group Loan / JLG (Joint Liability Group) ──────────────────────────
model GroupLoan {
  id              String    @id @default(cuid())
  tenantId        String
  groupName       String
  groupCode       String // Unique group identifier
  groupType       String    @default("JLG") // JLG | SHG | OTHER
  totalLoanAmount Decimal   @db.Decimal(15, 2)
  status          String    @default("active") // active | closed | npa
  formedDate      DateTime  @default(now())
  closedDate      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  members GroupLoanMember[]
  loans   Loan[]

  @@unique([tenantId, groupCode])
  @@map("group_loans")
}

model GroupLoanMember {
  id                   String    @id @default(cuid())
  groupLoanId          String
  memberId             String
  individualLoanAmount Decimal   @db.Decimal(15, 2)
  role                 String? // LEADER | MEMBER
  isActive             Boolean   @default(true)
  joinedAt             DateTime  @default(now())
  exitedAt             DateTime?

  groupLoan GroupLoan @relation(fields: [groupLoanId], references: [id])
  member    Member    @relation(fields: [memberId], references: [id])

  @@unique([groupLoanId, memberId])
  @@map("group_loan_members")
}

model Loan {
  id                     String    @id @default(cuid())
  tenantId               String
  memberId               String
  applicationId          String    @unique
  loanNumber             String
  loanType               String
  principalAmount        Decimal   @db.Decimal(15, 2)
  interestRate           Decimal   @db.Decimal(5, 2)
  penalRate              Decimal?  @db.Decimal(5, 2) // LN-006 penal interest
  tenureMonths           Int
  moratoriumMonths       Int       @default(0) // LN-005
  disbursedAmount        Decimal   @db.Decimal(15, 2)
  disbursedAt            DateTime?
  outstandingPrincipal   Decimal   @default(0) @db.Decimal(15, 2)
  outstandingInterest    Decimal   @default(0) @db.Decimal(15, 2)
  outstandingPenal       Decimal   @default(0) @db.Decimal(15, 2) // LN-006
  status                 String    @default("active") // active | closed | npa | written-off
  npaCategory            String? // LN-011: standard | sma_0 | sma_1 | sub_standard | doubtful_1 | doubtful_2 | doubtful_3 | loss
  npaDpd                 Int? // COA: days past due for oldest overdue EMI
  npaProvision           Decimal?  @db.Decimal(15, 2) // COA: provisioned amount
  npaDate                DateTime?
  writeOffDate           DateTime?
  writeOffAmount         Decimal?  @db.Decimal(15, 2)
  recoveredAmount        Decimal?  @default(0) @db.Decimal(15, 2)
  // CoA fields
  loanSubType            String? // COA: kcc | crop | livestock | gold | lad | shg | msme | housing | staff | micro | personal
  glCode                 String? // COA: assigned at disbursement from LOAN_GL_CODES
  subventionRate         Decimal?  @db.Decimal(5, 4) // COA: KCC 3% subvention
  goldValue              Decimal?  @db.Decimal(15, 2) // COA: appraised gold value (for gold loans)
  collateralFdrId        String? // COA: FDR ID used as collateral (for LAD)
  householdIncome        Decimal?  @db.Decimal(15, 2) // COA: declared income for microfinance cap
  bodResolutionRef       String? // COA: BOD resolution reference required for write-off
  // BRD v5.0 fields
  productId              String? // Link to LoanProduct
  disbursementMode       String? // CASH | NEFT | RTGS | INTERNAL_TRANSFER | DEMAND_DRAFT
  disbursementVoucherId  String?
  // LN-010: Restructuring/Refinance
  restructureCount       Int       @default(0) // Track number of restructures
  restructuredFromLoanId String? // Link to original loan if refinanced
  refinancedToLoanId     String? // Link to new loan if this was refinanced
  isRestructured         Boolean   @default(false) // Regulatory flag for NABARD reporting
  // LN-005: Moratorium tracking
  moratoriumEndDate      DateTime? // End date of moratorium period
  // LN-014: Guarantor
  guarantorMemberId      String? // Member ID if guarantor is existing member
  guarantorName          String? // External guarantor name
  guarantorIncome        Decimal?  @db.Decimal(15, 2) // Guarantor income/networth
  guaranteeAmount        Decimal?  @db.Decimal(15, 2) // Guarantee amount
  guaranteeStartDate     DateTime? // Guarantee start date
  // LN-023: Group Loan/JLG
  groupLoanId            String? // Link to GroupLoan if part of JLG
  // LN-024: CIBIL/Experian
  cibilScore             Decimal?  @db.Decimal(5, 2) // CIBIL credit score
  cibilReportDate        DateTime? // Date when CIBIL report was fetched
  cibilReportId          String? // CIBIL report reference ID
  experianScore          Decimal?  @db.Decimal(5, 2) // Experian credit score
  experianReportDate     DateTime? // Date when Experian report was fetched
  experianReportId       String? // Experian report reference ID
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  member              Member               @relation(fields: [memberId], references: [id])
  application         LoanApplication      @relation(fields: [applicationId], references: [id])
  emiSchedule         EmiSchedule[]
  restructuredFrom    Loan?                @relation("LoanRestructuring", fields: [restructuredFromLoanId], references: [id])
  refinancedTo        Loan[]               @relation("LoanRestructuring")
  groupLoan           GroupLoan?           @relation(fields: [groupLoanId], references: [id])
  // BRD v5.0 relations
  product             LoanProduct?         @relation(fields: [productId], references: [id])
  collateral          Collateral?
  disbursementVoucher DisbursementVoucher?

  @@unique([tenantId, loanNumber])
  @@map("loans")
}

model EmiSchedule {
  id            String    @id @default(cuid())
  loanId        String
  installmentNo Int
  dueDate       DateTime
  principal     Decimal   @db.Decimal(15, 2)
  interest      Decimal   @db.Decimal(15, 2)
  penalAmount   Decimal   @default(0) @db.Decimal(15, 2) // LN-006
  totalEmi      Decimal   @db.Decimal(15, 2)
  paidAmount    Decimal   @default(0) @db.Decimal(15, 2)
  paidAt        DateTime?
  status        String    @default("pending") // pending | paid | partial | overdue
  createdAt     DateTime  @default(now())

  loan Loan @relation(fields: [loanId], references: [id])

  @@map("emi_schedule")
}

// ─────────────────────────────────────────────
// BRD v5.0: LOAN MANAGEMENT MODULE 4
// ─────────────────────────────────────────────

// LN-P01 to LN-P07: Loan Product Master
model LoanProduct {
  id            String  @id @default(cuid())
  tenantId      String
  productCode   String // Auto-generated: LN-PROD-001
  productName   String
  category      String // PERSONAL | GOLD | HOUSING | AGRICULTURE | VEHICLE | EDUCATION | OTHER
  targetSegment String?
  description   String?
  isActive      Boolean @default(true)

  // Links (LN-P02)
  interestSchemeId         String? // Link to InterestScheme
  eligibilityRulesetId     String? // Reference to metadata key
  documentationChecklistId String? // Link to LoanDocumentChecklist
  repaymentStructure       String  @default("STANDARD_EMI") // STANDARD_EMI | BULLET | STEP_UP | IRREGULAR

  // Fee Structure (LN-P03)
  processingFeeType     String   @default("PERCENTAGE") // FLAT | PERCENTAGE
  processingFeeValue    Decimal  @db.Decimal(10, 2)
  documentationCharge   Decimal  @default(0) @db.Decimal(10, 2)
  insurancePremiumType  String? // FLAT | PERCENTAGE
  insurancePremiumValue Decimal? @db.Decimal(10, 2)
  gstOnFees             Decimal  @default(18.00) @db.Decimal(5, 2) // Platform-scope, statutory
  stampDutyPercent      Decimal? @db.Decimal(5, 2) // State-specific

  // Insurance Linkage (LN-P06)
  insuranceSchemeId String?

  // Maker-Checker (LN-P04)
  status          String    @default("DRAFT") // DRAFT | PENDING_APPROVAL | ACTIVE | SUPERSEDED | DEACTIVATED
  makerId         String?
  checkerId       String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  // Version History (LN-P07)
  version           Int     @default(1)
  previousVersionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  interestScheme     InterestScheme?         @relation(fields: [interestSchemeId], references: [id])
  applications       LoanApplication[]
  documentChecklists LoanDocumentChecklist[]
  loans              Loan[] // BRD v5.0: Loans using this product
  previousVersion    LoanProduct?            @relation("ProductVersions", fields: [previousVersionId], references: [id])
  versions           LoanProduct[]           @relation("ProductVersions")

  @@unique([tenantId, productCode])
  @@index([tenantId, status])
  @@map("loan_products")
}

// LN-DC01: Loan Document Checklist
model LoanDocumentChecklist {
  id                   String   @id @default(cuid())
  tenantId             String
  productId            String? // If product-specific
  documentName         String
  category             String // INCOME_PROOF | IDENTITY | ADDRESS | PROPERTY | GUARANTOR | COLLATERAL | INSURANCE | OTHER
  isMandatory          Boolean  @default(false)
  applicableCategories String[] // Loan categories this applies to
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  product          LoanProduct?          @relation(fields: [productId], references: [id])
  documentTrackers LoanDocumentTracker[]

  @@map("loan_document_checklists")
}

// LN-DC02 to LN-DC04: Loan Document Tracker
model LoanDocumentTracker {
  id              String    @id @default(cuid())
  applicationId   String
  checklistId     String
  documentName    String
  category        String
  isMandatory     Boolean
  status          String    @default("PENDING") // PENDING | SUBMITTED | UNDER_REVIEW | VERIFIED | REJECTED
  fileUrl         String?
  uploadedAt      DateTime?
  uploadedBy      String?
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?

  application LoanApplication       @relation(fields: [applicationId], references: [id])
  checklist   LoanDocumentChecklist @relation(fields: [checklistId], references: [id])

  @@unique([applicationId, checklistId])
  @@index([applicationId, status])
  @@map("loan_document_trackers")
}

// LN-COL01 to LN-COL04: Collateral Valuation & Mortgage
model Collateral {
  id              String   @id @default(cuid())
  tenantId        String
  applicationId   String   @unique // One-to-one with application
  loanId          String?  @unique // One-to-one with loan (set after loan creation)
  collateralType  String // PROPERTY | GOLD | VEHICLE | FDR | SHARES | OTHER
  description     String?
  valuationDate   DateTime
  valuationAmount Decimal  @db.Decimal(15, 2)
  valuerName      String?
  ltvRatio        Decimal  @db.Decimal(5, 2) // Auto-calculated

  // Gold-specific (LN-COL02)
  goldPurity        String? // Karatage
  goldGrossWeight   Decimal? @db.Decimal(10, 3) // grams
  goldNetWeight     Decimal? @db.Decimal(10, 3) // grams
  goldCertRefNumber String?
  goldRatePerGram   Decimal? @db.Decimal(10, 2)

  // Property-specific (LN-COL03)
  chargeType         String? // EQUITABLE_MORTGAGE | REGISTERED_MORTGAGE
  registrationDate   DateTime?
  subRegistrarOffice String?
  registrationNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  application LoanApplication @relation(fields: [applicationId], references: [id])
  loan        Loan?           @relation(fields: [loanId], references: [id])

  @@index([applicationId])
  @@index([loanId])
  @@map("collaterals")
}

// LN-CAN01 to LN-CAN06: Credit Appraisal Note
model CreditAppraisalNote {
  id            String @id @default(cuid())
  applicationId String @unique
  tenantId      String

  // Auto-generated content (LN-CAN01)
  memberProfileSummary      Json // Member details snapshot
  aiRiskScore               Decimal  @db.Decimal(5, 2)
  aiRiskExplanation         String?
  incomeAnalysis            Json?
  existingObligations       Json?
  proposedLoanTerms         Json?
  ltvRatio                  Decimal? @db.Decimal(5, 2)
  guarantorDetails          Json?
  documentStatusSummary     Json?
  loanOfficerRecommendation String // RECOMMEND | HOLD | REFER_COMMITTEE

  // Sanction Workflow (LN-CAN02, LN-CAN03)
  sanctionLevel       Int       @default(1) // 1, 2, or 3
  sanctionStatus      String    @default("PENDING") // PENDING | APPROVED | REJECTED | ESCALATED
  approvedBy          String?
  approvedAt          DateTime?
  rejectedBy          String?
  rejectedAt          DateTime?
  rejectionReasonCode String?
  rejectionReason     String?
  escalatedTo         String?
  escalatedAt         DateTime?

  // Exception Authorization (LN-CAN04)
  exceptionGranted       Boolean @default(false)
  exceptionJustification String?
  exceptionAuthorizedBy  String?

  // Credit Bureau (LN-CAN06)
  cibilScore         Decimal?  @db.Decimal(5, 2)
  cibilReportDate    DateTime?
  cibilReportId      String?
  experianScore      Decimal?  @db.Decimal(5, 2)
  experianReportDate DateTime?
  experianReportId   String?

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  application LoanApplication @relation(fields: [applicationId], references: [id])

  @@index([tenantId, sanctionStatus])
  @@map("credit_appraisal_notes")
}

// LN-CAN05: Loan Sanction Letter
model LoanSanctionLetter {
  id                 String  @id @default(cuid())
  applicationId      String  @unique
  tenantId           String
  sanctionedAmount   Decimal @db.Decimal(15, 2)
  approvedTenure     Int
  emiScheduleSummary Json
  totalInterestOutgo Decimal @db.Decimal(15, 2)
  securityDetails    Json?
  termsAndConditions String?

  // Member Acknowledgement
  acknowledgedAt DateTime?
  acknowledgedBy String? // Member ID or signature reference
  signatureUrl   String?

  generatedAt DateTime @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  application LoanApplication @relation(fields: [applicationId], references: [id])

  @@map("loan_sanction_letters")
}

// LN-DIS05: Disbursement Voucher
model DisbursementVoucher {
  id                 String   @id @default(cuid())
  loanId             String   @unique // One-to-one with loan
  tenantId           String
  voucherNumber      String
  disbursedAmount    Decimal  @db.Decimal(15, 2)
  disbursementDate   DateTime
  disbursementMode   String // CASH | NEFT | RTGS | INTERNAL_TRANSFER | DEMAND_DRAFT
  bankAccountDetails Json? // For NEFT/RTGS
  emiScheduleSummary Json
  firstEmiDueDate    DateTime
  memberSignatureUrl String? // For cash/internal transfer

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  loan   Loan   @relation(fields: [loanId], references: [id])

  @@unique([tenantId, voucherNumber])
  @@index([loanId])
  @@map("disbursement_vouchers")
}

