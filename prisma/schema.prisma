  assignedBy   String
  reason       String?
  createdAt    DateTime @default(now())

  user     User @relation(fields: [userId], references: [id])
  assigner User @relation("RoleAssigner", fields: [assignedBy], references: [id])

  @@index([tenantId, userId])
  @@map("role_assignment_logs")
}

// SEC-002: MFA Setup & Verification Log
model MfaLog {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String?
  action    String // SETUP | VERIFY | DISABLE | BACKUP_CODE_USED
  method    String // TOTP | SMS
  success   Boolean  @default(true)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("mfa_logs")
}

// SEC-005: DPDP Act 2023 - Data Access Request
model DataAccessRequest {
  id              String    @id @default(cuid())
  tenantId        String
  memberId        String
  requestType     String // ACCESS | CORRECTION | ERASURE
  status          String    @default("PENDING") // PENDING | IN_PROGRESS | FULFILLED | REJECTED
  requestedAt     DateTime  @default(now())
  fulfilledAt     DateTime?
  fulfilledBy     String?
  responseData    Json? // Data provided in response
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([tenantId, memberId])
  @@index([status])
  @@map("data_access_requests")
}

// SEC-005: DPDP Act 2023 - Data Correction Request
model DataCorrectionRequest {
  id          String    @id @default(cuid())
  tenantId    String
  memberId    String
  field       String // Field name to correct
  oldValue    String?
  newValue    String
  reason      String?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  requestedAt DateTime  @default(now())
  processedAt DateTime?
  processedBy String?
  auditTrail  Json? // Full audit trail of changes
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([tenantId, memberId])
  @@map("data_correction_requests")
}

// SEC-005: DPDP Act 2023 - Data Erasure Request
model DataErasureRequest {
  id               String    @id @default(cuid())
  tenantId         String
  memberId         String
  erasureType      String // FULL | PARTIAL | ANONYMIZE
  reason           String?
  status           String    @default("PENDING") // PENDING | PROCESSING | COMPLETED | REJECTED
  requestedAt      DateTime  @default(now())
  processedAt      DateTime?
  processedBy      String?
  anonymizedFields String[] // Fields that were anonymized (not deleted)
  deletedFields    String[] // Fields that were deleted
  retentionFields  String[] // Fields retained for legal compliance
  erasureLog       Json? // Complete erasure log
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([tenantId, memberId])
  @@map("data_erasure_requests")
}

// SEC-005: DPDP Act 2023 - Consent Management
model ConsentRecord {
  id             String    @id @default(cuid())
  tenantId       String
  memberId       String
  purpose        String // DATA_PROCESSING | MARKETING | SHARING | etc.
  consentGiven   Boolean   @default(false)
  consentDate    DateTime?
  withdrawalDate DateTime?
  method         String? // ONLINE | OFFLINE | VERBAL
  ipAddress      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@unique([tenantId, memberId, purpose])
  @@index([tenantId, memberId])
  @@map("consent_records")
}

// Module 11 — Third-Party Integrations

// INT-002, INT-011: Payment Requests (UPI, Payment Gateway)
model PaymentRequest {
  id            String    @id @default(cuid())
  tenantId      String
  orderId       String    @unique
  amount        Decimal
  purpose       String
  transactionId String?
  status        String    @default("PENDING") // PENDING | COMPLETED | FAILED | CANCELLED
  paymentMethod String // UPI | RAZORPAY | PAYU
  paymentId     String?
  referenceId   String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, orderId])
  @@index([transactionId])
  @@map("payment_requests")
}

// INT-003: NACH Auto-Debit Mandates
model NachMandate {
  id           String    @id @default(cuid())
  tenantId     String
  memberId     String
  mandateId    String    @unique
  bankAccount  String
  amount       Decimal
  frequency    String // MONTHLY | QUARTERLY | YEARLY
  startDate    DateTime
  endDate      DateTime?
  status       String    @default("PENDING") // PENDING | ACTIVE | REJECTED | CANCELLED | EXPIRED
  umrn         String? // Unique Mandate Reference Number
  registeredAt DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([tenantId, memberId])
  @@index([mandateId])
  @@map("nach_mandates")
}

// INT-005: SMS/Notification Logs
model NotificationLog {
  id           String    @id @default(cuid())
  tenantId     String
  memberId     String?
  type         String // SMS | EMAIL | PUSH | WHATSAPP
  recipient    String
  templateId   String?
  status       String    @default("PENDING") // PENDING | SENT | DELIVERED | FAILED
  messageId    String?
  subject      String?
  body         String?
  metadata     Json?
  sentAt       DateTime?
  deliveredAt  DateTime?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  member Member? @relation(fields: [memberId], references: [id])

  @@index([tenantId, memberId])
  @@index([messageId])
  @@index([status])
  @@map("notification_logs")
}

// ─────────────────────────────────────────────
// MODULE 16 — Interest Engine & Rate Management (BRD v4.0)
// ─────────────────────────────────────────────

// INT-001: Interest Rate Scheme Management
model InterestScheme {
  id                    String    @id @default(cuid())
  tenantId              String
  schemeCode            String
  schemeName            String
  productType           String // SB | FDR | RD | Loan
  interestMethod        String // SIMPLE | REDUCING_BALANCE | FLAT
  compoundingFreq       String // MONTHLY | QUARTERLY | ANNUALLY | SIMPLE
  slabApplicationMethod String    @default("FLAT") // FLAT | MARGINAL
  calculationBasis      String // Per interest.day.count.convention
  effectiveFromDate     DateTime
  effectiveToDate       DateTime?
  status                String    @default("DRAFT") // DRAFT | PENDING_APPROVAL | ACTIVE | SUPERSEDED | DEACTIVATED
  makerId               String? // User ID who created/modified
  checkerId             String? // User ID who approved
  submittedAt           DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?
  rateDeltaPct          Decimal?  @db.Decimal(5, 4) // For large-change routing
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  slabs        InterestSchemeSlab[]
  auditLogs    InterestSchemeAudit[]
  accruals     InterestAccrual[]
  loanProducts LoanProduct[] // BRD v5.0: Loan products using this scheme

  @@unique([tenantId, schemeCode])
  @@index([tenantId, productType, status])
  @@index([tenantId, effectiveFromDate, effectiveToDate])
  @@map("interest_schemes")
}

// INT-002: Slab-based Rate Configuration
model InterestSchemeSlab {
  id            String   @id @default(cuid())
  schemeId      String
  minAmount     Decimal? @db.Decimal(15, 2) // For balance-based slabs (SB)
  maxAmount     Decimal? @db.Decimal(15, 2)
  minTenureDays Int? // For tenure-based slabs (FDR/RD)
  maxTenureDays Int?
  rate          Decimal  @db.Decimal(5, 2) // Interest rate %
  createdAt     DateTime @default(now())

  scheme InterestScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  @@index([schemeId])
  @@map("interest_scheme_slabs")
}

// INT-013: Interest Audit Trail
model InterestSchemeAudit {
  id              String    @id @default(cuid())
  schemeId        String
  changeType      String // CREATED | MODIFIED | DEACTIVATED
  oldParameters   String // JSON snapshot
  newParameters   String // JSON snapshot
  changedBy       String // Maker user ID
  approvedBy      String? // Checker user ID
  changeDate      DateTime  @default(now())
  effectiveDate   DateTime
  approvalDate    DateTime?
  rejectionReason String?
  rateDeltaPct    Decimal?  @db.Decimal(5, 4)

  scheme InterestScheme @relation(fields: [schemeId], references: [id])

  @@index([schemeId])
  @@index([changeDate])
  @@map("interest_scheme_audit")
}

// INT-003, INT-009: Interest Accrual Records
model InterestAccrual {
  id               String    @id @default(cuid())
  tenantId         String
  accountId        String // SB account ID, Deposit ID, or Loan ID
  accountType      String // SB | FDR | RD | Loan
  schemeId         String?
  accrualDate      DateTime
  rateApplied      Decimal   @db.Decimal(5, 2)
  schemeVersion    String? // Scheme version used
  amountAccrued    Decimal   @db.Decimal(15, 2)
  calculationBasis String // Day-count convention used
  posted           Boolean   @default(false)
  postedAt         DateTime?
  createdAt        DateTime  @default(now())

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  scheme InterestScheme? @relation(fields: [schemeId], references: [id])

  @@unique([tenantId, accountId, accountType, accrualDate])
  @@index([tenantId, accountId, accountType])
  @@index([accrualDate])
  @@index([posted])
  @@map("interest_accruals")
}

// INT-010: Backdated Interest Recalculation Request
model RecalculationRequest {
  id                 String    @id @default(cuid())
  tenantId           String
  accountId          String
  accountType        String // SB | FDR | RD
  effectiveFromDate  DateTime
  reason             String
  requestedBy        String // User ID
  status             String    @default("DRAFT") // DRAFT | PENDING_APPROVAL | APPROVED | REJECTED
  submittedAt        DateTime?
  approvedAt         DateTime?
  approvedBy         String? // Checker user ID
  rejectedAt         DateTime?
  rejectedBy         String? // Checker user ID
  rejectionReason    String?
  reversalCount      Int?
  recalculationCount Int?
  netDifference      Decimal?  @db.Decimal(15, 2)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  requester User?  @relation("RecalculationRequester", fields: [requestedBy], references: [id])

  @@index([tenantId, status])
  @@index([accountId, accountType])
  @@index([status, submittedAt])
  @@map("recalculation_requests")
}

// MEM-027: Member Photograph Management
model MemberPhoto {
  id                String    @id @default(cuid())
  memberId          String
  tenantId          String
  purposeCode       String // ONBOARDING | RE_CAPTURE | KYC_RENEWAL
  captureMode       String // UPLOAD | WEBCAM
  filePath          String // Storage path (not exposed)
  imageHash         String // SHA-256 hash
  watermarkMetadata String? // JSON: member_id + tenant_id + timestamp
  isCurrent         Boolean   @default(false)
  status            String    @default("DRAFT") // DRAFT | PENDING_APPROVAL | APPROVED | REJECTED | ESCALATED | ACTIVE | HISTORICAL
  makerId           String? // User ID who captured
  checkerId         String? // User ID who approved
  submittedAt       DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String? // POOR_QUALITY | WRONG_MEMBER | CORRUPT_FILE
  escalatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([memberId, isCurrent])
  @@index([tenantId, status])
  @@index([status, submittedAt])
  @@map("member_photos")
}

// MEM-028: Member Signature Management
model MemberSignature {
  id                 String    @id @default(cuid())
  memberId           String
  tenantId           String
  purposeCode        String // ONBOARDING | RE_CAPTURE | MINOR_TO_MAJOR
  captureMode        String // UPLOAD | PAD
  filePath           String // Storage path (not exposed)
  imageHash          String // SHA-256 hash
  isCurrent          Boolean   @default(false)
  isGuardianSig      Boolean   @default(false) // For minor members
  guardianValidUntil DateTime? // DOB + 18 years
  status             String    @default("DRAFT") // DRAFT | VALIDATION | PENDING_APPROVAL | APPROVED | REJECTED | ESCALATED | ACTIVE | HISTORICAL
  makerId            String? // Secretary/Society Admin only
  checkerId          String? // Secretary/Society Admin
  submittedAt        DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String? // ILLEGIBLE | BLANK_SCAN | WRONG_MEMBER | LOW_QUALITY
  escalatedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([memberId, isCurrent])
  @@index([tenantId, status])
  @@index([status, submittedAt])
  @@map("member_signatures")
}
