  dueDate         DateTime
  responsibleRole String?
  status          String    @default("pending") // pending | completed | overdue
  lastAlertAt     DateTime?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("compliance_events")
}

// ─── GOV-006: By-law Repository ───────────────────────────────────────────────
model Bylaw {
  id            String   @id @default(cuid())
  tenantId      String
  version       Int      @default(1)
  title         String
  documentPath  String
  resolutionRef String? // BOD resolution reference for amendments
  effectiveDate DateTime @default(now())
  status        String   @default("active") // active | superseded
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  updatedBy     String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("bylaws")
}

// ─── GOV-007: Meeting Minutes & Action Items ──────────────────────────────────
model MeetingMinutes {
  id              String    @id @default(cuid())
  tenantId        String
  meetingType     String // BOARD | AGM | COMMITTEE
  meetingId       String // AGM ID or Committee ID
  meetingDate     DateTime
  minutesType     String    @default("DRAFT") // DRAFT | FINALIZED
  attendees       Json // [{memberId, name, role, present}]
  agenda          Json // [{id, title, description, decisions}]
  decisions       Json? // string[]
  actionItems     Json? // [{id, description, responsible, dueDate, status}]
  attachments     Json? // [{fileName, fileUrl}]
  sha256Hash      String? // GOV-015: For tamper detection
  digitallySigned Boolean   @default(false)
  signedAt        DateTime?
  signedBy        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agm    Agm?   @relation(fields: [meetingId], references: [id])

  @@map("meeting_minutes")
}

// ─── GOV-010: Exception Override Tracking ──────────────────────────────────────
model ApprovalOverride {
